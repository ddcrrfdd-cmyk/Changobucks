        return redirect(url_for('dashboard'))

    amount_raw = request.form.get('amount', '0').strip()
    method = request.form.get('method', '').strip().lower()
    details = request.form.get('details', '').strip()

    try:
        amount_val = float(amount_raw)
        if amount_val <= 0:
            raise ValueError
        amount_cents = int(round(amount_val * 100))
    except Exception:
        flash('Invalid amount.', 'danger')
        return redirect(url_for('dashboard'))

    if method not in ('paypal', 'stripe'):
        flash('Invalid payout method.', 'danger')
        return redirect(url_for('dashboard'))
    if not details:
        flash('Recipient details required.', 'danger')
        return redirect(url_for('dashboard'))

    # Verify balance
    user = get_user_by_id(current_user.id)
    if amount_cents > user.savings_cents:
        flash('Insufficient savings.', 'danger')
        return redirect(url_for('dashboard'))

    idempotency = secrets.token_hex(16)

    # 1) Deduct pessimistically & record pending payout
    conn = sqlite3.connect(DB_PATH)
    try:
        conn.execute(
            "UPDATE users SET savings_cents = savings_cents - ? WHERE id = ?",
            (amount_cents, current_user.id)
        )
        conn.execute(
            '''INSERT INTO payouts
               (user_id, amount_cents, method, details, status, idempotency_key)
               VALUES (?, ?, ?, ?, ?, ?)''',
            (current_user.id, amount_cents, method, details, 'pending', idempotency)
        )
        conn.commit()
    except Exception as e:
        conn.rollback()
        conn.close()
        logger.error("Payout pre-deduction failed: %s", e)
        flash('Internal error initiating payout.', 'danger')
        return redirect(url_for('dashboard'))
    conn.close()

    # 2) Call external gateway
    try:
        if method == 'paypal':
            send_paypal_payout(amount_cents, details)
        elif method == 'stripe':
            send_stripe_payout(amount_cents, details)

        # Success
        conn = sqlite3.connect(DB_PATH)
        conn.execute(
            "UPDATE payouts SET status = ?, completed_at = ? WHERE idempotency_key = ?",
            ('completed', datetime.utcnow().isoformat(), idempotency)
        )
        conn.commit()
        conn.close()
        flash('${:,.2f} sent via {}!'.format(amount_val, method.upper()), 'success')
    except Exception as e:
        logger.error("Gateway error: %s", e)
        # 3) Rollback on failure
        conn = sqlite3.connect(DB_PATH)
        conn.execute(
            "UPDATE users SET savings_cents = savings_cents + ? WHERE id = ?",
            (amount_cents, current_user.id)
        )
        conn.execute(
            "UPDATE payouts SET status = ?, error_message = ? WHERE idempotency_key = ?",
            ('failed', str(e)[:500], idempotency)
        )
        conn.commit()
        conn.close()
        flash('Payout failed: {}. Funds returned to savings.'.format(str(e)), 'danger')

    return redirect(url_for('dashboard'))

