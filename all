    stripe_key = os.environ.get('STRIPE_API_KEY')
    if not stripe_key:
        raise RuntimeError("Stripe API key missing")
    stripe.api_key = stripe_key
    idempotency = secrets.token_hex(16)
    transfer = stripe.Transfer.create(
        amount=amount_cents,
