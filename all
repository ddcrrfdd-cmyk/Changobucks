# --- REVENUE STREAM PROCESSORS ---
def process_api_stream(name, api_func, multiplier=1):
    try:
        result = api_func()
        if result:
            earned_cents = int(float(result) * multiplier * 100)
            if earned_cents > 0:
                conn = sqlite3.connect(DB_PATH)
                conn.execute('''UPDATE revenue_streams SET earnings_cents = earnings_cents + ?, last_run = ? WHERE name = ?''', (earned_cents, datetime.utcnow().isoformat(), name))
                conn.commit()
                conn.close()
    except Exception as e:
        logger.warning(f"{name} tick failed: {e}")

def process_fixed_stream(name):
    try:
        conn = sqlite3.connect(DB_PATH)
        conn.row_factory = sqlite3.Row
        row = conn.execute("SELECT * FROM revenue_streams WHERE name = ?", (name,)).fetchone()
        if row:
            last_run = datetime.fromisoformat(row['last_run']) if row['last_run'] else datetime.utcnow()
            interval = row['interval_seconds']
            rate = row['rate_cents']
            now = datetime.utcnow()
            elapsed = (now - last_run).total_seconds()
            if elapsed >= interval:
                ticks = int(elapsed // interval)
                earned_cents = ticks * rate
                new_last = last_run + timedelta(seconds=ticks * interval)
                conn.execute('''UPDATE revenue_streams SET earnings_cents = earnings_cents + ?, last_run = ? WHERE name = ?''', (earned_cents, new_last.isoformat(), name))
                conn.commit()
        conn.close()
    except Exception as e:
        logger.warning(f"{name} tick failed: {e}")

