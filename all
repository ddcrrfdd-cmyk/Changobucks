                    "sender_batch_id": f"batch_{int(time.time())}",
                    "email_subject": "Changobucks Payout!",
                    "email_message": f"Your payout of ${amount} has been sent."
                },
                "items": [{
                    "recipient_type": "EMAIL",
                    "amount": {"value": amount, "currency": "USD"},
                    "receiver": details,
                    "note": "Payout from Changobucks"
                }]
            }
            response = requests.post(paypal_url, headers=headers, json=payload)
            if response.status_code == 201:
                cursor = db.cursor()
                cursor.execute('INSERT INTO payouts (user_id, amount, method, status, timestamp) VALUES (?, ?, ?, ?, ?)',
                              (1, amount, method, "success", datetime.now().isoformat()))
                db.commit()
                return {"status": "success", "method": "paypal"}
            else:
                return {"status": "error", "message": "PayPal API Error"}
        elif method == "stripe":
            stripe.api_key = os.environ.get('STRIPE_API_KEY')
            intent = stripe.PaymentIntent.create(amount=int(amount * 100), currency="usd")
